{{- if (and (eq .chezmoi.os "linux") (not .codespaces)) -}}
#!/bin/bash

set -eufo pipefail

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

echo "Update brew repositories"
brew update

brew bundle --file=/dev/stdin <<EOF
{{ range (.packages.linux.brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
EOF
{{ end -}}
